{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Playwright tests",
      "program": "${workspaceFolder}/node_modules/.bin/playwright",
      "args": ["test", "--headed", "--workers=1"],
      "console": "integratedTerminal",
      "env": { "PWDEBUG": "1" },
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
